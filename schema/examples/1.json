      "initial": "CREATING_CONTRACT",
      "realities": {
        "CREATING_CONTRACT": {
          "id": "CREATING_CONTRACT",
          "type": "transition",
          "on": {
            "create-contract": [
              {
                "condition": {
                  "src": "condition:ifItIsTheTemplate",
                  "args": { "templateId": "M6AKG7rJ52itfWWroUcHgT" }
                },
                "targets": ["SIGNING_CONTRACT"]
              }
            ],
            "cancel": [{ "targets": ["U:admission-cancelled:CANCELLED"] }]
          },
          "entryActions": [
            {
              "src": "action:sendContract",
              "args": {
                "templateId": "M6AKG7rJ52itfWWroUcHgT",
                "arg_injection_answers_from": [
                  "crm-admission.applicant-light-info-admission-survey",
                  "crm-admission.guardian-info-admission-survey",
                  "crm-admission.substitute-guardian-admission-info-survey",
                  "crm-admission.data-consent-admission-survey"
