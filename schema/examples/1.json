    "school-validation-confirmation-process": {
      "id": "school-validation-confirmation-process",
      "canonicalName": "school-validation-confirmation-process",
      "initial": "WAITING_CONFIRMATION",
      "realities": {
        "WAITING_CONFIRMATION": {
          "id": "WAITING_CONFIRMATION",
          "observers": [
            {
              "src": "builtin:observer:totalEventsBetweenLimits",
              "args": { "minimum": 10 }
            }
          ],
          "type": "transition",
          "on": {
            "confirm": [
              {
                "conditions": [
                  {
                    "src": "condition:ifItIsTheTemplateFromUniverse",
                    "args": {
                      "templateId": "school-validation-confirmation-process"
                    }
                  },
                  { "src": "condition:isMadeByCampus" }
                ],
                "targets": ["CONFIRMED"]
              }
            ],
            "cancel": [{ "targets": ["U:admission-cancelled:CANCELLED"] }]
          }
        },
        "CONFIRMED": {
          "id": "CONFIRMED",
          "always": [{ "targets": ["U:data-consent-form-process"] }],
          "type": "final",
          "on": null,
          "entryInvokes": [
            {
              "src": "invoke:sendNotification",
              "args": {
                "notificationId": "admission_school_validation_confirmed_email"
              }
            }
          ]
        }
      },
      "version": "0.1.0",
      "metadata": {
        "templateType": "confirmation-process",
        "templateDescription": "",
        "templateOrder": 11,
        "notifyAdmissionUser": true,
        "isCampusOperation": true,
        "templateId": "school-validation-confirmation-process",
        "templateLabel": "Validación del Colegio",
        "templateGroup": "",
        "notificationId": "admission_school_validation_confirmed_email"
      }
    },
