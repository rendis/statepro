{
  "name": "@rendis/statepro-studio-react",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "dist",
    "src/styles.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate:builtin-catalog": "node ../../scripts/generate-builtin-behaviors.mjs",
    "dev": "tsup src/index.ts --format esm,cjs --dts --sourcemap --watch",
    "build": "pnpm run generate:builtin-catalog && tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "test": "pnpm run generate:builtin-catalog && vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: pendiente de reglas'"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.18",
    "ajv": "^8.17.1",
    "elkjs": "^0.11.0",
    "lucide-react": "^0.468.0",
    "react-zoom-pan-pinch": "^3.7.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^26.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
